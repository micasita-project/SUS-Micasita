# PostgreSQL connection string
# Railway: se genera automáticamente al agregar el plugin PostgreSQL
DATABASE_URL=postgresql://usuario:contraseña@host:5432/nombre_db

# URL(s) del frontend separadas por coma (sin barra final)
FRONTEND_URL=https://tu-app.netlify.app

# Puerto (Railway lo inyecta automáticamente, no cambiar)
PORT=3000
